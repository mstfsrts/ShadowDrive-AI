// ─── ShadowDrive AI — Prisma Schema ───
// PostgreSQL (Dokploy)
// Auth.js v5 compatible models + app-specific models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js required models ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  progress               Progress[]
  scenarios              GeneratedScenario[]
  favorites              Favorite[]
  customLessons          CustomLesson[]
  pronunciationAttempts  PronunciationAttempt[]
  lessonReports          LessonReport[]
  dailyActivities        DailyActivity[]
  goal                   UserGoal?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App-specific models ────────────────────────────────────────────────────

model Progress {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  lessonId        String
  lastLineIndex   Int       @default(0)
  completed       Boolean   @default(false)
  completedAt     DateTime?
  completionCount Int       @default(0)
  targetCount     Int       @default(4)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId])
}

model GeneratedScenario {
  id        String  @id @default(cuid())
  userId    String?
  topicHash String
  topic     String
  title     String?
  level     String
  content   Json

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([topicHash])
  @@index([userId])
}

model Favorite {
  id       String  @id @default(cuid())
  userId   String
  courseId String?
  lessonId String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId])
}

// ─── Course content (DB-only, seeded from prisma/seed.ts) ─────────────────

model Course {
  id          String   @id
  title       String
  description String
  emoji       String
  color       String
  order       Int      @default(0)
  category    String
  subcategory String?
  lessons     Lesson[]
}

model Lesson {
  id       String @id
  courseId String
  title    String
  order    Int    @default(0)
  content  Json

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ─── User-created content ────────────────────────────────────────────────────

model CustomLesson {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Pronunciation & Progress Tracking ────────────────────────────────────────

model PronunciationAttempt {
  id           String   @id @default(cuid())
  userId       String
  lessonType   String   // "course" | "ai" | "custom"
  lessonId     String
  lessonTitle  String
  lineIndex    Int
  targetText   String
  transcript   String
  score        Float    // 0.0 - 1.0
  correct      Boolean
  recordingUrl String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([userId, createdAt])
}

model LessonReport {
  id           String   @id @default(cuid())
  userId       String
  lessonType   String   // "course" | "ai" | "custom"
  lessonId     String
  lessonTitle  String
  totalLines   Int
  correctCount Int
  averageScore Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([userId, createdAt])
}

model DailyActivity {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  lessonsCount    Int      @default(0)
  practiceMinutes Int      @default(0)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model UserGoal {
  id           String @id @default(cuid())
  userId       String @unique
  dailyTarget  Int    @default(2)
  weeklyTarget Int    @default(10)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
