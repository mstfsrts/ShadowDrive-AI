{
    "name": "shadowdrive-ai",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "backend",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm -w frontend run dev",
        "build": "npm -w frontend run build",
        "start": "npm -w frontend run start",
        "test": "npm -w frontend run test",
        "lint": "npm -w frontend run lint",
        "dev:backend": "npm -w backend run dev",
        "build:backend": "npm -w backend run build",
        "db:generate": "npm -w frontend run db:generate",
        "db:migrate": "npm -w frontend run db:migrate",
        "db:seed": "npm -w backend run db:seed"
    }
}
